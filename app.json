{
  "expo": {
    "name": "Substrack",
    "slug": "substrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Substrack-Logo.png",
    "scheme": "substrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.barisgunduz.substrack",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.barisgunduz.substrack"
        ]
      }
    },
    "android": {
      "package": "com.barisgunduz.substrack",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Substrack-Logo.png",
        "monochromeImage": "./assets/images/Substrack-Logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Substrack-Logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Substrack-Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
